```
# Android build artifacts
*.apk
*.aar
*.dex

# Android dependency directories
.libs/
.externalNativeBuild/
.gradle/
local.properties

# IDE files
.idea/
*.iml
*.iws
.vscode/

# Build directories
build/
bin/
gen/
out/

# Log files
*.log

# Environment
.env
.env.local
*.env.*

# Temporary files
*.tmp
*.temp
*~
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python cache (if any Python files exist in the project)
__pycache__/
*.pyc
*.pyo
*.pyd

# Node modules (if any JS/TS files exist in the project)
node_modules/

# Virtual environments (if any Python files exist in the project)
venv/
.venv/
```